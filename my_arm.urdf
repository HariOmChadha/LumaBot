<?xml version="1.0"?>
<robot name="5dof_arm">

  <link name="world"/>
  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <geometry><sphere radius="0.01"/></geometry>
    </visual>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <!-- JOINT 1: at origin -->
  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0.0 0.0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.5707" upper="1.5707" effort="10" velocity="1.0"/>
  </joint>

  <link name="link1">
    <visual>
      <geometry><sphere radius="0.01"/></geometry>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <!-- JOINT 2 -->
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0.0 0.0 0.044" rpy="0 1.5707 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.5707" upper="1.5707" effort="10" velocity="1.0"/>
  </joint>

  <link name="link2">
    <visual>
      <geometry><sphere radius="0.01"/></geometry>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <!-- JOINT 3 -->
  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="-0.140 0.0 0.0" rpy="3.1416 0 2.0943"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.5707" upper="1.5707" effort="10" velocity="1.0"/>
  </joint>

  <link name="link3">
    <visual>
      <geometry><sphere radius="0.01"/></geometry>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <!-- JOINT 4 -->
  <joint name="joint4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="0.105 0.005 0.014" rpy="-1.5707 -1.5707 -1.5707"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.5707" upper="1.5707" effort="10" velocity="1.0"/>
  </joint>

  <link name="link4">
    <visual>
      <geometry><sphere radius="0.01"/></geometry>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <!-- JOINT 5 -->
  <joint name="joint5" type="revolute">
    <parent link="link4"/>
    <child link="link5"/>
    <origin xyz="0.016 -0.006 0.029" rpy="1.5707 -1.5707 1.5707"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.5707" upper="1.5707" effort="10" velocity="1.0"/>
  </joint>

  <link name="link5">
    <visual>
      <geometry><sphere radius="0.01"/></geometry>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <!-- END EFFECTOR -->
  <link name="end_effector">
    <visual>
      <geometry><sphere radius="0.015"/></geometry>  <!-- slightly bigger so you can spot it -->
    </visual>
  </link>
  <joint name="ee_joint" type="fixed">
    <parent link="link5"/>
    <child link="end_effector"/>
    <origin xyz="0.03 0 0" rpy="0 0 0"/>
  </joint>

</robot>